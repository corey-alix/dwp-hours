PORT=3000
NODE_ENV=development
HASH_SALT=your-secret-salt-here
SMTP_HOST=your-smtp-host
SMTP_PORT=587
SMTP_USER=your-smtp-username
SMTP_PASS=your-smtp-password
SENDER_NAME=Your App Name
SENDER_EMAIL=sender@example.com

# ── Feature Flags ──
# Override feature flags via environment variables.
# If not set, defaults from shared/businessRules.ts are used.
# Accepted values: true/1 (enabled) or false/0 (disabled).

# FF_ENABLE_BROWSER_IMPORT=true    # Parse Excel in browser (avoids server OOM)
# FF_ENABLE_IMPORT_AUTO_APPROVE=true  # Auto-approve clean PTO entries on import

# ── Azure AD / Entra ID ──
# Enable Azure AD authentication for corporate SSO.
# Set AZURE_AD_ENABLED=true and fill in the IDs from your Azure app registration.
# AZURE_AD_CLIENT_SECRET is the only true secret — never commit it.

# AZURE_AD_ENABLED=false
# AZURE_AD_TENANT_ID=your-directory-tenant-id
# AZURE_AD_CLIENT_ID=your-application-client-id
# AZURE_AD_CLIENT_SECRET=your-client-secret
# AZURE_AD_REDIRECT_URI=http://localhost:3000/api/auth/azure/callback