PORT=3000
NODE_ENV=development
HASH_SALT=your-secret-salt-here
SMTP_HOST=your-smtp-host
SMTP_PORT=587
SMTP_USER=your-smtp-username
SMTP_PASS=your-smtp-password
SENDER_NAME=Your App Name
SENDER_EMAIL=sender@example.com

# ── Feature Flags ──
# Override feature flags via environment variables.
# If not set, defaults from shared/businessRules.ts are used.
# Accepted values: true/1 (enabled) or false/0 (disabled).

# FF_ENABLE_BROWSER_IMPORT=true    # Parse Excel in browser (avoids server OOM)
# FF_ENABLE_IMPORT_AUTO_APPROVE=true  # Auto-approve clean PTO entries on import